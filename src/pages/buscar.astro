---
import { teams } from '../data/equipos.js';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>NFL Teams - Buscar</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet" />
    <style>
      * {
        font-family: 'Inter', sans-serif;
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background-color: #0f0f0f;
        min-height: 100vh;
        padding: 3rem;
      }

      h1 {
        color: white;
        font-size: 2.5rem;
        margin-bottom: 2rem;
      }

      .search-input {
        width: 100%;
        max-width: 500px;
        padding: 1rem 1.5rem;
        border-radius: 12px;
        border: none;
        background-color: #1e1e1e;
        color: white;
        font-size: 1.1rem;
        margin-bottom: 3rem;
        outline: none;
      }

      .search-input::placeholder {
        color: rgba(255,255,255,0.3);
      }

      .search-input:focus {
        background-color: #2a2a2a;
      }

      .results {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
      }

      .card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 280px;
        height: 380px;
        border-radius: 20px;
        cursor: pointer;
        transition: transform 0.2s ease;
        padding: 2rem;
        box-sizing: border-box;
      }

      .card:hover {
        transform: scale(1.05);
      }

      .card img {
        width: 150px;
        height: 150px;
        object-fit: contain;
      }

      .card h2 {
        color: white;
        font-size: 1.8rem;
        margin: 1rem 0 0.3rem;
        text-shadow: 1px 1px 4px rgba(0,0,0,0.5);
      }

      .card p {
        color: white;
        font-size: 1rem;
        opacity: 0.85;
        text-shadow: 1px 1px 4px rgba(0,0,0,0.5);
      }

      .no-results {
        color: rgba(255,255,255,0.4);
        font-size: 1.2rem;
        display: none;
      }
    </style>
  </head>
  <body>
    <h1>Buscar equipo</h1>
    <input 
      class="search-input" 
      type="text" 
      placeholder="Ej: Patriots, Titans, Kansas..."
      id="searchInput"
    />
    <p class="no-results" id="noResults">No se encontraron equipos.</p>
    <div class="results" id="results">
      {teams.map((team) => (
        <div 
          class="card" 
          data-name={team.nombreCompleto.toLowerCase()}
          style={`background-color: ${team.colores.principal}`}
        >
          <img src={team.logo} alt={`Logo ${team.nombre}`} />
          <h2>{team.nombre}</h2>
          <p>{team.ultimoRecord}</p>
        </div>
      ))}
    </div>

    <script>
      const input = document.getElementById('searchInput');
      const cards = document.querySelectorAll('.card');
      const noResults = document.getElementById('noResults');

      input.addEventListener('input', () => {
        const query = input.value.toLowerCase();
        let visibles = 0;

        cards.forEach((card) => {
          const name = card.dataset.name;
          if (name.includes(query)) {
            card.style.display = 'flex';
            visibles++;
          } else {
            card.style.display = 'none';
          }
        });

        noResults.style.display = visibles === 0 ? 'block' : 'none';
      });
    </script>
  </body>
</html>